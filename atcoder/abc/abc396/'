#include <bits/stdc++.h>
#define _ ios_base::sync_with_stdio(0);cin.tie(0);
#define endl '\n'
#define all(x) (x).begin(), (x).end()
#define rall(x) (x).rbegin(), (x).rend()
typedef long long ll;
using namespace std;
#define int ll

struct Bit {
	int n;
	vector<int> F;
	Bit (int n_) : n(n_), F(n + 1) { }
	void update(int i, int x) {
		for (i++; i <= n; i+=i&-i) {
			F[i] += x;
		}
	}

	int pref(int i) {
		int res = 0;
		for (i++; i; i-=i&-i) {
			res += F[i];
		}
		return res;
	}
};


int solve() {
	int n, m; cin >> n >> m;
	vector<int> A(n);
	vector<vector<int>> O(m);
	for (int i = 0; i < n; i++) {
		cin >> A[i];
		O[A[i]].push_back(i);
	}

	vector<int> L(n), R(n);
	Bit bita(m), bitb(m);
	for (int i = 0; i < n; i++) {
		L[i] = bita.pref(A[i] - 1);
		bita.update(A[i], + 1);
	}

	int res = 0;
	for (int i = n-1; i >= 0; i--) {
		R[i] = n - i - 1 - bitb.pref(A[i]);
		res += bitb.pref(A[i] - 1);
	}

	for (int k = 0; k < m; k++) {
		for (int i : O[m - k]) {
			res += L[i];
			res -= R[i];
		}
		cout << res << endl;
	}

    return(0);
}

signed main()
{
    _;

	int t = 1; //cin >> t;
	while (t--) {
		solve();
	}
    
    return(0);
}

