#!/bin/python3

def heapify(V, n, i):
    l = 2 * i + 1
    r = 2 * i + 2
    if l < n and V[l] > V[i]:
        maior = l
    else:
        maior = i
    if r < n and V[r] > V[maior]:
        maior = r
    if maior != i:
        V[maior],V[i] = V[i],V[maior]
        heapify(V, n, maior)

def build_heap(V, n):
    inicio = (int)(n/2) - 1
    for i in range(inicio,-1,-1):
        heapify(V, n, i)

def heapsort(V, n):
    build_heap(V, n)
    for i in range(n-1, -1, -1):
        V[0],V[i] = V[i],V[0]
        n = n - 1
        heapify(V, n, 0)

numbers = [int(x) for x in input().split()]
heapsort(numbers, len(numbers)-1)
print(numbers)
