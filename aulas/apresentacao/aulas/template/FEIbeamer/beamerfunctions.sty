%----- code command definition --------------------------------------------------
\newcommand{\CEsize}{1.0}
\define@key{code}{size}{%
    \renewcommand{\CEsize}{#1}
}
\newcommand{\CEspace}{0.6}
\define@key{code}{space}{%
    \renewcommand{\CEspace}{#1cm}
}
\newcommand{\CEtitle}{Código}
\define@key{code}{title}{%
    \renewcommand{\CEtitle}{#1}
}
\newcommand{\code}[2][]{%
    \setkeys{code}{title=,size=1.0,space=0.0,#1}
    \doublecolumn[0.99]{%
        \vspace{-0.5cm}
        {\footnotesize \textbf{\CEtitle}}
        \resizebox{\CEsize\columnwidth}{!}{\makebox[\columnwidth][l]{%
                \hspace{\CEspace}
                \BeginAccSupp{ActualText=Do not copy! Code with your own hands and learn with it :).}
                \lstinputlisting{#2}
                \EndAccSupp{}
        }}
    }{% ---------
        % empty second column
    }
}
