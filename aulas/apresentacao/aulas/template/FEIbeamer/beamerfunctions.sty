%----- splitcodethree command definition --------------------------------------
\newcommand{\SCTsize}{1.0}
\define@key{splitcodethree}{size}{%
    \renewcommand{\SCTsize}{#1}
}

\newcommand{\SCTtitle}{Código}
\define@key{splitcodethree}{title}{%
    \renewcommand{\SCTtitle}{#1}
}
\newcommand{\splitcodethree}[4][]{%
    \setkeys{splitcodethree}{size=1.0,title=,#1}
    \triplecolumn{%
        {\footnotesize \textbf{\SCTtitle}}
        \resizebox{\SCTsize\columnwidth}{!}{\makebox[\columnwidth][l]{
                \hspace{0.0cm}
                \BeginAccSupp{ActualText=Do not copy! Code with your own hands and learn with it :).}
                \lstinputlisting[lastline=#2]{#4}
                \EndAccSupp{}
        }}
    }{% ---------
        \resizebox{\SCTsize\columnwidth}{!}{\makebox[\columnwidth][l]{
                \FPeval{\firstSplit}{clip(1+#2)}
                \hspace{0.0cm}
                \BeginAccSupp{ActualText=Do not copy! Code with your own hands and learn with it :).}
                \lstinputlisting[firstline=\firstSplit,firstnumber=\firstSplit,lastline=#3]{#4}
                \EndAccSupp{}
        }}
    }{% ---------
        \resizebox{\SCTsize\columnwidth}{!}{\makebox[\columnwidth][l]{
                \FPeval{\secondSplit}{clip(1+#3)}
                \hspace{0.0cm}
                \BeginAccSupp{ActualText=Do not copy! Code with your own hands and learn with it :).}
                \lstinputlisting[firstline=\secondSplit,firstnumber=\secondSplit]{#4}
                \EndAccSupp{}
        }}
    }
}
