%----- balloon command definition (begin) ----------------------------------------------
\newcounter{ballooncounter}
\setcounter{ballooncounter}{0}% 

\newcommand{\BLxshift}{1.0cm}
\newcommand{\BLyshift}{1.0cm}
\newcommand{\BLfollow}{BLempty}
\newcommand{\BLx}{1.0cm}
\newcommand{\BLy}{1.0cm}
\newcommand{\BLfont}{\footnotesize}
\newcommand{\BLtextalign}{center}
\newcommand{\BLtextwidth}{0}

\define@key{balloon}{xshift}{%
    \renewcommand{\BLxshift}{#1cm}
}
\define@key{balloon}{yshift}{%
    \renewcommand{\BLyshift}{#1cm}
}
\define@key{balloon}{follow}{%
    \renewcommand{\BLfollow}{#1}
}
\define@key{balloon}{x}{%
    \renewcommand{\BLx}{#1}
}
\define@key{balloon}{y}{%
    \renewcommand{\BLy}{#1}
}
\define@choicekey{balloon}{font}{\tiny,\scriptsize,\footnotesize,\small,\normalsize,\large,\Large,\LARGE,\huge,\Huge}{%
    \renewcommand{\BLfont}{#1}
}
\define@key{balloon}{align}{%
    \renewcommand{\BLtextalign}{#1}
}
\define@key{balloon}{textwidth}{%
    \renewcommand{\BLtextwidth}{#1}
}
\newcommand{\balloon}[2][]{%
    \addtocounter{ballooncounter}{1}%
    \setkeys{balloon}{align=center,font=\footnotesize,xshift=1.0,yshift=1.0,x=8,y=4,follow=BLempty,#1}%
    \ifthenelse{\equal{\BLfollow}{BLempty}}%
    {\renewcommand{\BLfollow}{BL\theballooncounter}\floatnode[x=\BLx,y=\BLy]{\tikzmark{\BLfollow}}}%
    {}%
    \ifthenelse{\equal{\BLtextwidth}{0}}{%
        \tikzstyle{balloon}=[rectangle callout,rounded corners,]
    }
    {%
        \tikzstyle{balloon}=[rectangle callout,rounded corners,text width=\BLtextwidth cm]
    }
    \begin{tikzpicture}[overlay, remember picture]%
        \node[balloon,align=\BLtextalign,font=\BLfont,%
        callout absolute pointer={(pic cs:\BLfollow)},%
        draw] at ([xshift=\BLxshift,yshift=\BLyshift]pic cs:\BLfollow){#2};
    \end{tikzpicture}
}
%----- balloon command definition (end) ----------------------------------------------


