% ---------- double columns command definition ------------------------------------
% create two columns with adjustable size. The informed parameter will be used
% to define a percetage of the page used by the first column.
% The remaining size will be filled by the second column
\newcommand{\doublecolumn}[3][0.5]{% 
    \begin{columns}[onlytextwidth,T]
        \FPeval{\result}{clip(1.0-#1)}
        \begin{column}{#1\textwidth}
            \setlength{\parskip}{\baselineskip}
            #2
        \end{column}
        \begin{column}{\result\textwidth}
            \setlength{\parskip}{\baselineskip}
            #3
        \end{column}
    \end{columns}
}
%------------------------------------------------------------------------------


% -------- triplecolumn command definition ----------------------------------
% create three columns with fixed size
\newcommand{\triplecolumn}[3]{%
    \begin{columns}[onlytextwidth,T]
        \begin{column}{0.33\textwidth}
            \setlength{\parskip}{\baselineskip}
            #1
        \end{column}
        \begin{column}{0.33\textwidth} 
            \setlength{\parskip}{\baselineskip}
            #2
        \end{column}
        \begin{column}{0.33\textwidth}
            \setlength{\parskip}{\baselineskip}
            #3
        \end{column}
    \end{columns}
}
