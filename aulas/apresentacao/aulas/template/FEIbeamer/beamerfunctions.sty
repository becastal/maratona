%-----grid command definition (begin)------------------------------------
\newcommand{\grid}{
    \tikz[overlay, remember picture, help lines]{
        \foreach \x in {0,...,18} \path (current page.south west) +(\x,0.2) node {\textcolor{cyan!70}{\small$\x$}};
        \foreach \y in {0,...,9} \path (current page.south west) +(0.10,\y) node {\textcolor{cyan!70}{\small$\y$}};
        \foreach \x in {0,0.5,...,18.5} \draw[cyan!30] (current page.south west) ++(\x,0) -- +(0,9.6);
        \foreach \y in {0,0.5,...,9.5} \draw[cyan!30] (current page.south west) ++(0,\y) -- +(18.8,0);
    }
}
%-----grid command definition (end)------------------------------------



%----- floatnode command definition (begin)-------------------------------------------
\newcommand{\FNxpos}{8.0}
\newcommand{\FNypos}{4.0}
\newcommand{\FNnodealign}{left}
\newcommand{\FNfont}{\footnotesize}
\newcommand{\FNanchor}{anchor}

\define@boolkey{floatnode}{grid}{
    \tikz[overlay, remember picture, help lines]{
        \foreach \x in {0,...,18} \path (current page.south west) +(\x,0.2) node {\textcolor{cyan!70}{\small$\x$}};
        \foreach \y in {0,...,9} \path (current page.south west) +(0.10,\y) node {\textcolor{cyan!70}{\small$\y$}};
        \foreach \x in {0,0.5,...,18.5} \draw[cyan!30] (current page.south west) ++(\x,0) -- +(0,9.6);
        \foreach \y in {0,0.5,...,9.5} \draw[cyan!30] (current page.south west) ++(0,\y) -- +(18.8,0);
    }
}
\define@key{floatnode}{x}{%
    \renewcommand{\FNxpos}{#1}
}
\define@key{floatnode}{y}{%
    \renewcommand{\FNypos}{#1}
}
\define@key{floatnode}{align}{%
    \renewcommand{\FNnodealign}{#1}
}
\define@choicekey{floatnode}{font}{\tiny,\scriptsize,\footnotesize,\small,\normalsize,\large,\Large,\LARGE,\huge,\Huge}{%
    \renewcommand{\FNfont}{#1}
}
\define@key{floatnode}{anchor}{%
    \renewcommand{\FNanchor}{#1}
}
\newcommand{\floatnode}[2][]{%
    \setkeys{floatnode}{font=\footnotesize,anchor=center,x=8.0,y=4.0,align=left,#1}%
    \tikz[remember picture,overlay]\node[font=\FNfont,anchor=\FNanchor,align=\FNnodealign]at ($(current page.south west)+(\FNxpos, \FNypos)$) {#2};%
}
%------floatnode command definition (end)-----------------------------------------------


