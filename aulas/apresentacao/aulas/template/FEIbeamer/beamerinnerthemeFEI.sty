\mode<presentation>

\setbeamertemplate{navigation symbols}{} % remove navigation symbols
\setbeamertemplate{frametitle}[default][left]
\setbeamertemplate{itemize items}[circle]
\setbeamertemplate{itemize subitem}{--}
\setbeamertemplate{blocks}[rounded][shadow=true]


% define title page layout
\setbeamertemplate{title page}
{%
  % \setbeamercolor{background canvas}{bg=ANIMAdarkgreen}
  % \setbeamercolor{background canvas}{bg=FEIdarkblue}
  \setbeamercolor{background canvas}{bg=FEIlightblue}
  \begin{frame}[plain] % plain causes the headline, footline and sidebars to be suppressed

    % \fimage{-5.0}{-0.4}{\includegraphics[scale=0.68]{FEI_logo_2015.png}}
    \floatnode[x=14.2,y=7.5]{\includegraphics[scale=0.30]{FEI_logo_2015.png}}

    \begin{columns}[onlytextwidth,T]
      \begin{column}{.12\linewidth}
        % empty left space
      \end{column}
      \begin{column}{.88\linewidth}
        \parbox[c][0.55\paperheight][b]{1.0\columnwidth}
        {%
          {\usebeamerfont{title}\usebeamercolor[fg]{title}\inserttitle}
        }
        \parbox[c][0.15\paperheight][c]{1.0\columnwidth}{%
          {\usebeamercolor[fg]{subtitle}\usebeamerfont{subtitle}\insertsubtitle}%
        }
        \parbox[t][0.15\paperheight][c]{1.0\columnwidth}
        {%
          \usebeamercolor[fg]{author}
          \insertauthor\\
          \insertshortauthor%
        }
      \end{column}
    \end{columns}
  \end{frame}
}

% define end page layout
\setbeamertemplate{endpage}
{%
  % \setbeamercolor{background canvas}{bg=ANIMAdarkgreen}
  \setbeamercolor{background canvas}{bg=FEIlightblue}
  \begin{frame}[plain]
    \parbox[c][0.55\paperheight][b]{1.0\columnwidth}
    {%
      {\usebeamerfont{title}\usebeamercolor[fg]{title}Obrigado}
    }
    \parbox[c][0.27\paperheight][c]{1.0\columnwidth}{%
      {\usebeamercolor[fg]{subtitle}\usebeamerfont{subtitle}\insertshortauthor}%
    }
  \end{frame}
}


% insert titlepage as the first page
\AtBeginDocument{\ifthenelse{\boolean{hascover}}{\titlepage}{}}
% insert endpage as the last page 
\AtEndDocument{\ifthenelse{\boolean{hascover}}{\usebeamertemplate{endpage}}{}}


