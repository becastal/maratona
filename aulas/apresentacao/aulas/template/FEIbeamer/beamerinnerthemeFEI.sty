    % \begin{columns}
    %   \begin{column}{0.40\paperwidth}
    %     % \setbeamercolor{background canvas}{bg=FEIlightblue}
    %     \parbox[c][0.30\paperheight][b]{1.0\columnwidth} {}
    %     \parbox[c][0.30\paperheight][b]{1.0\columnwidth}
    %     {%
    %       {\usebeamercolor[fg]{title}\rtndfamily\inserttitle} 
    %     }
    %   \end{column}
    %   \begin{column}{0.50\paperwidth}
    %     \centering
    %     {\Large\insertsectionhead}
    %   \end{column}
    % \end{columns} 
    \colorbox{FEIlightblue}{\begin{minipage}[c][1.0\paperheight][c]
        % {\dimexpr0.5\textwidth-2\fboxsep-2\fboxrule-5pt\relax}
        {\dimexpr0.5\textwidth-2\fboxsep-2\fboxrule-5pt\relax}
