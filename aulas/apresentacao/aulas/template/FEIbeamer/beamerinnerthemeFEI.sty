}

% define note page layout
\setbeamertemplate{note page}{%
  \floatnode[y=4]{\crule[notegray]{16cm}{10cm}}%
  \floatnode[x=8, y=8]{\crule[lightgray]{16cm}{2.25cm}}%
  \floatnode[font=\large,x=1,y=8,anchor=west]{Notas e Soluções}%
  \floatnode[x=14, y=8]{\insertslideintonotes{0.25}}%
  \floatnode[x=1, y=7.1,align=left,anchor=west]{\inserttitle}%
  \vspace{1.7cm}%
  \par
  \insertnote%
  % \grid
}

\mode%
<all>
