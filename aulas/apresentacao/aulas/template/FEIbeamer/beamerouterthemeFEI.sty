\mode<presentation>


\setbeamertemplate{headline}
{%
  \leavevmode%
  \textcolor{FEImiddleblue}{\rule{\paperwidth}{6pt}} % draw a line
  \vskip0pt%
}

\setbeamertemplate{footline}
{%
  \leavevmode%
  \begin{beamercolorbox}[wd=1.00\paperwidth,ht=0.30cm,dp=1ex,right]{date in head/foot}%
    \usebeamerfont{date in head/foot}
    \textcolor{FEIdarkblue}{\insertframenumber{}} \hspace*{2ex} 
  \end{beamercolorbox}
  \textcolor{FEImiddleblue}{\rule{\paperwidth}{3pt}} % draw a line
  \vskip0pt%
}
\mode%
<all>

