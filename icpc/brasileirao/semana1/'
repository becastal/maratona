#include <bits/stdc++.h>
#define _ ios_base::sync_with_stdio(0);cin.tie(0);
#define endl '\n'
#define all(x) (x).begin(), (x).end()
#define rall(x) (x).rbegin(), (x).rend()
typedef long long ll;
using namespace std;
#define int ll

/*

achar quem eh o kesimo: digit dp + bb
depois uma digit dp diferenciada pra soma dos digitos sse o numero nao tem nenhum zero

*/

const int mod = 1e9 + 7;
int solve() {
	__int128_t n; cin >> n;
	__int128_t l = 1, r = __int128_t(1) << 65, kesimo = l;

	auto cont_zero = [&](int a) {
		vector dp(20, vector(20, vector(2, vector<int>(2, -1))));
		string S = to_string(a);

		function<int(int, int, int, int)> f = [&](int pos, int tight, int zero_e, int tem_zero) -> int {
			if (pos == S.size()) return tem_zero;	
			auto& res = dp[pos][tight][zero_e][tem_zero];
			if (res != -1) return res;

			res = 0;
			int teto = tight ? S[pos] - '0' : 9;

			for (int i = 0; i <= teto; i++) {
				res += f(pos + 1,
						 tight and (i == teto),
						 zero_e and (i == 0),
						 tem_zero or (!zero_e and !i));
			}
			return res;
		};
		return f(0, 1, 1, 0);
	};

	//cout << "cont_zero(3): " << cont_zero(3) << endl;
	//cout << "cont_zero(20): " << cont_zero(20) << endl;
	while (l <= r) {
		int mid = l + (r - l) / 2;

		if (mid - cont_zero(mid) >= n) {
			r = mid - 1;
			kesimo = mid;
		} else {
			l = mid + 1;
		}
	}
	//cout << "kesimo: " << kesimo << endl;

	string S = to_string(kesimo);
	int tot = 0;

	for (int dig = 1; dig <= 9; dig++) {
		vector dp(20, vector(2, vector(2, vector(2, vector<int>(20, -1)))));

		function<int(int, int, int, int, int)> f = [&](int pos, int tight, int zero_e, int tem_zero, int cont) -> int {
			if (pos == S.size()) return !tem_zero * cont;	
			auto& res = dp[pos][tight][zero_e][tem_zero][cont];
			if (res != -1) return res;

			res = 0;
			int teto = tight ? S[pos] - '0' : 9;

			for (int i = 0; i <= teto; i++) {
				res += f(pos + 1,
						 tight and (i == teto),
						 zero_e and (i == 0),
						 tem_zero or (!zero_e and i == 0),
						 cont + (i == dig));
			}
			return res;
		};
		tot = (tot + dig * f(0, 1, 1, 0, 0)) % mod;
	}
	cout << tot << endl;

	return(0);
}

signed main()
{
    _;

	int t = 1; //cin >> t;
	while (t--) {
		solve();
	}
    
    return(0);
}

